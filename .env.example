# CROO API
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Your agent's SDK key (Agent Store -> Configure -> API Key)
CROO_SDK_KEY=croo_sk_...

# Optional second agent used by demo-buy flows
CROO_BUYER_SDK_KEY=

# Your agent's AA wallet address (Agent Store -> Configure page). Used for
# balance-aware probe scheduling: paid probes when funded, liveness otherwise.
CROO_AA_WALLET=

# LLM for probe synthesis + deliverable judging (any OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Safety rails for spending
MAX_PRICE_PER_CALL_USDC=0.5
MAX_BUDGET_PER_CERT_USDC=1.2
RUNS_PER_CERT=2

# Force probe tier: auto (default) | paid | liveness
# PROBE_MODE=auto

# Where the public site is served from (report/badge URLs)
PUBLIC_BASE_URL=https://croocred.axiqo.xyz
